# Copy to nucleus.toml. This file contains ONLY non-identifying tunables —
# anything that uniquely identifies a user, channel, account, or path lives
# in `.env` (gitignored). See `.env.example`.

[claude]
binary = "claude"
# auto = per-call classifier (recommended). Other choices:
# default, acceptEdits, plan, dontAsk, bypassPermissions
permission_mode = "auto"
disallowed_tools = [
  "Bash(rm *)",
  "Bash(sudo *)",
  "Bash(diskutil *)",
  "Bash(dd *)",
  "Bash(shutdown *)",
  "Bash(reboot *)",
  "Bash(launchctl *)",
]

[discord]
# How the Discord bot decides whether to respond.
mention_only_in_channels = true
dms_always_respond = true

[obsidian]
# Path to your Obsidian vault. Tilde-expanded at load.
vault_path = "~/Documents/Obsidian"

[news]
# Once daily at 9am local time. Adjust to taste.
fetch_cron = "0 9 * * *"

[diary]
root = "memory/diaries"
retain_days = 7

[distiller]
# ADR-016: one consolidated daily pass (extract → judge → archive → prune),
# replacing the old hourly-metabolism + weekly-contemplation split. The real
# schedule lives in tools/launchd/distiller.plist.example; this is documentary.
cron = "0 4 * * *"
# model = "claude-sonnet-4-6"   # optional override (reserved; unused today)

[skill_learner]
# ADR-017: the skill-gap learner. On-the-fly arm reviews a conversation after
# this many turns per chat; periodic arm proposes missing skills + curates.
nudge_interval = 12
cron = "30 4 * * *"          # periodic `learn` (informational; truth in the plist)
stale_after_days = 30        # agent-created skills idle this long → stale
archive_after_days = 90      # …this long → auto-archived (never deleted)
enabled = true

[gmail]
# Daily inbox metabolism (ADR-007). 5am local; cron evaluated in NUCLEUS_TZ.
metabolism_cron = "0 5 * * *"
# Cheap classifier — taxonomy is small and the rubric is fixed.
classifier_model = "claude-haiku-4-5"
# Auto-promote a sender to the kill-list after this many junk hits.
killlist_auto_promote_threshold = 3
# Default duration applied to calendar events scheduled via the
# `--channel calendar` reminder path when no explicit end time is given.
calendar_default_duration_min = 30

[reminders]
# Default output routing for system-prompt reminders (ADR-008) when
# neither the stored prompt nor --channels specifies where results
# should go. Body-based reminders aren't affected — they always use
# their own per-reminder channels.
default_channels = ["discord-home"]

[ports]
# Single operator app per ADR-015. Serves dashboard widgets, chat,
# the public news API, and every admin surface from one origin.
# Public news routes at /news/api/* stay through cloudflared; the
# rest gates behind Tailscale per ADR-011.
nucleus_dashboard = 8092

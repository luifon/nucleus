<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>__LAUNCHD_PREFIX__.news-fetcher</string>
    <key>ProgramArguments</key>
    <array>
        <string>__USER_HOME__/Development/nucleus/target/release/news-fetcher</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__USER_HOME__/Development/nucleus</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>TZ</key>
        <string>__TZ__</string>
        <key>NUCLEUS_LOG</key>
        <string>info</string>
        <key>NUCLEUS_CLAUDE_BIN</key>
        <string>__USER_HOME__/.local/bin/claude</string>
        <key>PATH</key>
        <string>__USER_HOME__/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>RunAtLoad</key>
    <false/>
    <key>StandardOutPath</key>
    <string>__USER_HOME__/Development/nucleus/memory/news-fetcher.log</string>
    <key>StandardErrorPath</key>
    <string>__USER_HOME__/Development/nucleus/memory/news-fetcher.log</string>
</dict>
</plist>

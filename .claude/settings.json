{
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && python3 tools/stamp-skill-last-used.py"
          }
        ]
      }
    ]
  }
}

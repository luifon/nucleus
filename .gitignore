target/
**/*.rs.bk
**/node_modules/
**/dist/
**/auth/
**/auth.old-*/

# runtime data — Tier 1 per-bot state
memory/*
!memory/.gitkeep

# secrets
.env
.env.*
!.env.example
secrets/

# sqlite leftovers
*.db
*.db-shm
*.db-wal

# logs
*.log

# os
.DS_Store

# editor
.vscode/
.idea/
*.swp

# local-only configs
nucleus.toml
tools/cloudflared/*.yaml
!tools/cloudflared/*.yaml.example
tools/launchd/*.plist
!tools/launchd/*.plist.example
tools/caddy/caddy
tools/caddy/Caddyfile
tools/caddy/*.plist
!tools/caddy/*.plist.example
tools/caddy/data/

# NoobAI (SDXL) backend venv — heavy, regenerated by `uv sync` (ADR-019)
tools/noobai/.venv/
__pycache__/
*.pyc

# personal Claude Code overrides (hooks + permissions for this operator only)
.claude/settings.local.json
.claude/secret-strings

# personal project state — see docs/SECRETS.md
docs/ROADMAP.md
docs/TODO.md
docs/PRIVATE.md

# design exploration / throwaway mocks
design-mocks/

# playwright-mcp screenshot + snapshot artifacts
.playwright-mcp/
*-news-*.png
*-news-*.yml

# ts-rs default export dirs — side effect of plain `cargo test` runs
# without TS_RS_EXPORT_DIR; the real generated types live at
# nucleus-dashboard/web/src/lib/api/generated/ (Rule 12).
core/bindings/
chores/reminders/bindings/
nucleus-dashboard/api/bindings/

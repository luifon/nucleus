# Copy to .env and fill in. The .env file is gitignored — everything that
# could identify a specific user, account, channel, or path lives here, not
# in nucleus.toml.

# ---- secrets ----
DISCORD_BOT_TOKEN=

# ---- personal identifiers ----
# Your name (used to template personas and prompts).
NUCLEUS_USER_NAME=

# Absolute path to this workspace.
NUCLEUS_WORKSPACE_ROOT=/path/to/nucleus

# Absolute path to Tier 2 shared-memory dir. The default is
# `$HOME/.claude/projects/<encoded-cwd>/memory/` — set this explicitly to make
# the location unambiguous and machine-independent.
NUCLEUS_TIER2_DIR=

# Discord channel + user IDs.
DISCORD_HOME_CHANNEL_ID=
DISCORD_ALLOWED_USER_IDS=    # comma-separated

# launchd service prefix. Defaults to `dev.nucleus` if unset. install.sh
# substitutes this into the plist Label and the on-disk filename in
# ~/Library/LaunchAgents/, producing e.g. `dev.nucleus.discord.plist`.
NUCLEUS_LAUNCHD_PREFIX=

# Timezone used to interpret StartCalendarInterval times in the plists.
# launchd binds whatever TZ was active at plist-load time; if you change
# system TZ later, scheduled jobs keep firing on the OLD TZ until you
# reload them. Setting this explicitly + re-running install.sh removes
# that footgun. If unset, install.sh auto-detects from /etc/localtime.
NUCLEUS_TZ=

# Public URLs for the tunnel-fronted services. Optional — if unset, the
# corresponding tunnel health check is skipped and any cross-link in the UI
# is hidden. Set the ones you actually expose via Cloudflare (or whatever).
NUCLEUS_NEWS_PUBLIC_URL=
NUCLEUS_DASHBOARD_PUBLIC_URL=
NUCLEUS_CONTAINERS_PUBLIC_URL=
NUCLEUS_CHAT_PUBLIC_URL=

# WhatsApp has TWO channel ROLES, each with its own allowlist. Both accept
# group names (resolved to JIDs at startup) and raw JIDs:
#
#   ALFRED (conversational): you message → Claude replies. Voice memos
#     transcribed and answered. The classic "talking to the bot" channel.
#       WHATSAPP_ALLOWED_GROUP_NAMES — group names like "Alfred"
#       WHATSAPP_ALLOWED_CHAT_IDS    — raw JIDs (120363...@g.us)
#
#   BRAIN DUMP (capture-only): you message → bot files into PARA-organized
#     Obsidian vault (T3). Voice memos transcribed and filed as notes. Bot
#     may reply with confirmation or escalate when classification is uncertain.
#       WHATSAPP_BRAINDUMP_GROUP_NAMES — group names like "Brain Dump"
#       WHATSAPP_BRAINDUMP_CHAT_IDS    — raw JIDs
#
# Recommended setup: two self-only groups, one named e.g. "Alfred" for chat
# and another named e.g. "Brain Dump" for capture. Whichever role a JID is
# in determines its pipeline; brain-dump assignments take precedence on
# accidental overlap.
WHATSAPP_ALLOWED_GROUP_NAMES=
WHATSAPP_ALLOWED_CHAT_IDS=
WHATSAPP_BRAINDUMP_GROUP_NAMES=
WHATSAPP_BRAINDUMP_CHAT_IDS=

# Personal email JARVIS adds as attendee on calendar events scheduled via
# the `--channel calendar` reminder path (ADR-007). The Gmail/Calendar MCP
# is authenticated against the trash account ($NUCLEUS_GMAIL_ACCOUNT),
# so events live there; this is the address invites are sent to so they
# land on the personal calendar with native phone/watch alerts.
NUCLEUS_PERSONAL_EMAIL=

# mem0 user namespace (typically just your handle/first name in lowercase).
# Held for the future — S4 (mem0 wiring) is deferred indefinitely, see ADR-001.
MEM0_USER_ID=

# ---- runtime tunables ----
NUCLEUS_LOG=info

# Override the `claude` binary path if not on PATH.
# NUCLEUS_CLAUDE_BIN=/usr/local/bin/claude

# Override the whisper.cpp model path and binary if not at the defaults.
# Defaults: ~/.cache/whisper/models/ggml-large-v3.bin and `whisper-cli` on PATH.
# WHISPER_MODEL_PATH=/absolute/path/to/ggml-large-v3.bin
# WHISPER_BINARY=whisper-cli

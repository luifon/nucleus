# Copy to .env and fill in. The .env file is gitignored — everything that
# could identify a specific user, account, channel, or path lives here, not
# in nucleus.toml.

# ---- secrets ----
DISCORD_BOT_TOKEN=

# ---- personal identifiers ----
# Your name (used to template personas and prompts).
NUCLEUS_USER_NAME=

# Absolute path to this workspace.
NUCLEUS_WORKSPACE_ROOT=/path/to/nucleus

# Absolute path to the cloned Bonsai-Image-Demo checkout (image generation
# backend for the /gallery surface, ADR-019). Leave unset if not using it.
NUCLEUS_BONSAI_DIR=/path/to/Bonsai-Image-Demo

# Absolute path to Tier 2 shared-memory dir. The default is
# `$HOME/.claude/projects/<encoded-cwd>/memory/` — set this explicitly to make
# the location unambiguous and machine-independent.
NUCLEUS_TIER2_DIR=

# Browser profile for the Playwright MCP server (committed in .mcp.json).
# Pinning the profile path keeps logins (AppFlowy etc.) stable across
# @playwright/mcp upgrades — an upstream version once moved its default
# profile dir and silently logged every bot out. Defaults to
# `$HOME/.nucleus/playwright-profile` if unset.
NUCLEUS_PLAYWRIGHT_PROFILE=

# Discord channel + user IDs.
DISCORD_HOME_CHANNEL_ID=
DISCORD_ALLOWED_USER_IDS=    # comma-separated

# launchd service prefix. Defaults to `dev.nucleus` if unset. install.sh
# substitutes this into the plist Label and the on-disk filename in
# ~/Library/LaunchAgents/, producing e.g. `dev.nucleus.discord.plist`.
NUCLEUS_LAUNCHD_PREFIX=

# Timezone used to interpret StartCalendarInterval times in the plists.
# launchd binds whatever TZ was active at plist-load time; if you change
# system TZ later, scheduled jobs keep firing on the OLD TZ until you
# reload them. Setting this explicitly + re-running install.sh removes
# that footgun. If unset, install.sh auto-detects from /etc/localtime.
NUCLEUS_TZ=

# Public URL for nucleus-dashboard. Optional — if unset, the tunnel
# health check tile is hidden, and the news-fetcher's Discord posts
# omit "view full" links to news.
NUCLEUS_PUBLIC_URL=
NUCLEUS_CONTAINERS_PUBLIC_URL=

# WhatsApp has TWO channel ROLES, each with its own allowlist. Both accept
# group names (resolved to JIDs at startup) and raw JIDs:
#
#   ALFRED (conversational): you message → Claude replies. Voice memos
#     transcribed and answered. The classic "talking to the bot" channel.
#       WHATSAPP_ALLOWED_GROUP_NAMES — group names like "Alfred"
#       WHATSAPP_ALLOWED_CHAT_IDS    — raw JIDs (120363...@g.us)
#
#   BRAIN DUMP (capture-only): you message → bot files into PARA-organized
#     Obsidian vault (T3). Voice memos transcribed and filed as notes. Bot
#     may reply with confirmation or escalate when classification is uncertain.
#       WHATSAPP_BRAINDUMP_GROUP_NAMES — group names like "Brain Dump"
#       WHATSAPP_BRAINDUMP_CHAT_IDS    — raw JIDs
#
# Recommended setup: two self-only groups, one named e.g. "Alfred" for chat
# and another named e.g. "Brain Dump" for capture. Whichever role a JID is
# in determines its pipeline; brain-dump assignments take precedence on
# accidental overlap.
WHATSAPP_ALLOWED_GROUP_NAMES=
WHATSAPP_ALLOWED_CHAT_IDS=
WHATSAPP_BRAINDUMP_GROUP_NAMES=
WHATSAPP_BRAINDUMP_CHAT_IDS=

# WhatsApp DM mode (ADR-005b). Allowlist of JIDs the bot will accept DMs
# from. Empty default = DM listening disabled (group-only behavior,
# unchanged). For the single-operator case the value is your own JID
# (`<digits>@s.whatsapp.net`) — message your own bot number once, find
# the JID in the Baileys connection log, paste here. Comma-separated.
# Brain-dump-shaped DMs are still rejected with a nudge to use the
# brain-dump group; ADR-005b keeps capture group-scoped.
WHATSAPP_ALLOWED_DM_JIDS=

# Per-sender authorization — comma-separated. Even inside an allowlisted
# group, only messages from these senders are processed (defense against
# someone adding the bot to a group with a colliding name and spamming).
# Accepts either phone numbers (`5511999999999`) or LIDs (`123456789012345`).
# Both forms are normalized to digits-only; suffixes (`@s.whatsapp.net`,
# `@lid`, `:device`) and formatting (`+`, spaces, hyphens) are stripped.
# Use your phone number; the LID fallback is useful before the
# bot has built up its LID↔PN map (logged when dropped — paste it in
# here if you want to short-circuit the wait).
WHATSAPP_ALLOWED_SENDERS=

# Persona slugs per venue (ADR-009). Each value resolves to
# `personas/<slug>.md` at spawn time and is fed into the session's
# --append-system-prompt. Ship templates: `assistant` and `robot`. Point
# multiple venues at the same slug for a unified voice across surfaces,
# or set them independently for per-venue personas. After ADR-005b lands
# you can also set NUCLEUS_PERSONA_WHATSAPP_DM / _BRAINDUMP for
# per-context overrides.
NUCLEUS_PERSONA_DISCORD=assistant
NUCLEUS_PERSONA_WHATSAPP=assistant
NUCLEUS_PERSONA_GMAIL=assistant

# Gmail trash account JARVIS operates on (ADR-007). The Claude.ai Gmail +
# Calendar MCPs are authenticated against whichever Google account you've
# linked at claude.ai — JARVIS treats *that* as the trash account.
# Substituted into the resolved Gmail persona and the metabolism prompt
# via `${GMAIL_ACCOUNT}`.
NUCLEUS_GMAIL_ACCOUNT=

# Personal email JARVIS adds as attendee on calendar events scheduled via
# the `--channel calendar` reminder path (ADR-007). Events live on the
# trash account (see above); invites land here, so they reach your main
# calendar with native phone/watch alerts.
NUCLEUS_PERSONAL_EMAIL=

# mem0 user namespace (typically just your handle/first name in lowercase).
# Held for the future — S4 (mem0 wiring) is deferred indefinitely, see ADR-001.
MEM0_USER_ID=

# ---- runtime tunables ----
NUCLEUS_LOG=info

# Override the `claude` binary path if not on PATH.
# NUCLEUS_CLAUDE_BIN=/usr/local/bin/claude

# Override the whisper.cpp model path and binary if not at the defaults.
# Defaults: ~/.cache/whisper/models/ggml-large-v3.bin and `whisper-cli` on PATH.
# WHISPER_MODEL_PATH=/absolute/path/to/ggml-large-v3.bin
# WHISPER_BINARY=whisper-cli
